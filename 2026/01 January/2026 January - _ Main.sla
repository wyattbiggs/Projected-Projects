            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="4642.524" OwnPage="13" ItemID="278016032" PTYPE="4" WIDTH="153" HEIGHT="13.5" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L153 0 L153 13.5 L0 13.5 L0 0 Z" copath="M0 0 L153 0 L153 13.5 L0 13.5 L0 0 Z" gXpos="532.0008" gYpos="2034.5112" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle FONT="Consolas Bold Italic" FONTSIZE="10"/>
                <ITEXT FONT="Consolas Bold Italic" FONTSIZE="10" CH="Method-Setup Continued"/>
                <trail/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="311.5008" YPOS="4642.524" OwnPage="13" ItemID="278018864" PTYPE="4" WIDTH="148.5" HEIGHT="220.5" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L148.5 0 L148.5 220.5 L0 220.5 L0 0 Z" copath="M0 0 L148.5 0 L148.5 220.5 L0 220.5 L0 0 Z" gXpos="311.5008" gYpos="4642.524" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FONT="Consolas Regular" FONTSIZE="10" CH="The first fully printed dragon had a defect: while printing the first few layers, one of the dragon's links detached from the build plate and imbedded itself into another portion of the dragon, fusing several links together (hereafter  referred to as an inclusion defect). Printing a second time with the same settings produced the first dragon without defects [Fig. 3.2]."/>
                <trail LINESPMode="0" LINESP="13"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="536.5008" YPOS="4822.524" OwnPage="14" ItemID="278013200" PTYPE="4" WIDTH="148.5" HEIGHT="58.5" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L148.5 0 L148.5 58.5 L0 58.5 L0 0 Z" copath="M0 0 L148.5 0 L148.5 58.5 L0 58.5 L0 0 Z" gXpos="536.5008" gYpos="4822.524" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FONT="Consolas Regular" FONTSIZE="10" CH="without defects using an initial layer height of 0.3mm and adaptive cubic infill."/>
                <trail/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="541.0008" YPOS="4642.524" OwnPage="14" ItemID="278007536" PTYPE="2" WIDTH="144" HEIGHT="144" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0.560975609756042" LOCALY="-0.382230832122332" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" PRFILE="sRGB display profile (ICC v2.2)" IRENDER="0" path="M0 0 L144 0 L144 144 L0 144 L0 0 Z" copath="M0 0 L144 0 L144 144 L0 144 L0 0 Z" gXpos="541.0008" gYpos="4642.524" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1"/>
        <PAGEOBJECT XPOS="707.5008" YPOS="4822.524" OwnPage="14" ItemID="278030192" PTYPE="4" WIDTH="148.5" HEIGHT="121.5" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L148.5 0 L148.5 121.5 L0 121.5 L0 0 Z" copath="M0 0 L148.5 0 L148.5 121.5 L0 121.5 L0 0 Z" gXpos="707.5008" gYpos="4822.524" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle LINESP="12" FONT="Consolas Regular" FONTSIZE="10"/>
                <ITEXT FONT="Consolas Regular" FONTSIZE="10" CH="suffered the same defect as the second attempt."/>
                <ITEXT CH=" The build plate was removed, handwashed over a sink with water and handsoap, dried with a flour sack towel, and placed back in the X1C. The two proceeding prints had no defects."/>
                <trail/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="5312.5272" OwnPage="15" ItemID="278033024" PTYPE="4" WIDTH="153" HEIGHT="337.5" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L153 0 L153 337.5 L0 337.5 L0 0 Z" copath="M0 0 L153 0 L153 337.5 L0 337.5 L0 0 Z" gXpos="136.0008" gYpos="5312.5272" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle LINESP="13" FONT="Consolas Regular" FONTSIZE="10"/>
                <ITEXT CH="The articulation of each final dragons is fully functional and behaves as predicted, having the most freedom about the pitch axis, followed by yaw and then roll. No tools were used to measure the physical properties, but the dual-colored PLA has physical properties roughly equivalent to that of single-colored PLA. The Pink-Blue PLA filament produces in the most visually interesting surface finish, followed by a tie between the Blue-Green PLA filament and the Gold-Magenta PLA filament. The dragons printed at 75% scale provide a more enjoyable fidgeting experience compared to the dragon printed at 125% scale."/>
                <trail/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="5677.0272" OwnPage="15" ItemID="278021696" PTYPE="4" WIDTH="153" HEIGHT="135" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L153 0 L153 135 L0 135 L0 0 Z" copath="M0 0 L153 0 L153 135 L0 135 L0 0 Z" gXpos="136.0008" gYpos="5677.0272" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle LINESP="13" FONT="Consolas Regular" FONTSIZE="10"/>
                <ITEXT CH="Because the model was sourced from MakerWorld rather than designed from scratch, this project demonstrates only that small"/>
                <nbhyphen/>
                <ITEXT CH="scale, chain"/>
                <nbhyphen/>
                <ITEXT CH="like articulations are feasible; meaningful modifications beyond simple scaling are not possible without"/>
                <trail/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="307.0008" YPOS="5303.5272" OwnPage="15" ItemID="278035856" PTYPE="4" WIDTH="153" HEIGHT="193.5" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L153 0 L153 193.5 L0 193.5 L0 0 Z" copath="M0 0 L153 0 L153 193.5 L0 193.5 L0 0 Z" gXpos="307.0008" gYpos="5303.5272" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FONT="Consolas Regular" FONTSIZE="10" CH="developing a fully parametric model. The mechanical differences between single- and dual-colored filament would require a load frame and standard testing methods for 3D prints which would likely be similar to existing tensile strength tests (ASTM D638/ISO 527) [5] but would have to account for the anisotropy of the 3D printed test coupons. "/>
                <trail LINESP="13"/>
            </StoryText>
        </PAGEOBJECT>
    </DOCUMENT>
</SCRIBUSUTF8NEW>
