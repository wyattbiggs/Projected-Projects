        <PAGEOBJECT XPOS="140.5008" YPOS="4656.024" OwnPage="13" ItemID="277993376" PTYPE="4" WIDTH="148.5" HEIGHT="76.5" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L148.5 0 L148.5 76.5 L0 76.5 L0 0 Z" copath="M0 0 L148.5 0 L148.5 76.5 L0 76.5 L0 0 Z" gXpos="140.5008" gYpos="4656.024" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
