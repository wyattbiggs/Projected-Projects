        <PAGEOBJECT XPOS="703.0008" YPOS="5402.5272" OwnPage="16" ItemID="198504864" PTYPE="4" WIDTH="153" HEIGHT="265.5" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L153 0 L153 265.5 L0 265.5 L0 0 Z" copath="M0 0 L153 0 L153 265.5 L0 265.5 L0 0 Z" gXpos="703.0008" gYpos="3446.5176" gWidth="0" gHeight="0" ALIGN="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle ALIGN="0" LINESP="12" FONT="Consolas Regular" FONTSIZE="10"/>
                <ITEXT FONT="Consolas Regular" FONTSIZE="10" CH="Because a handful of friends wanted an articulated  dragon as a toy, dragons of different sizes and colors were printed in dual-color filament. The quality of the articulation was of interest due to the potential use of articulating components in novel and currently unimagined products. The physical properties and appearance of dual-color filaments was of interest as it results in a some-what iridescent surface finish which could prove useful in projects with an ornamental rather than purely functional aim. "/>
                <trail ALIGN="0" LINESP="12"/>
            </StoryText>
        </PAGEOBJECT>
