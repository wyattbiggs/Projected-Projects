        <PAGEOBJECT XPOS="703.0008" YPOS="5946.5304" OwnPage="18" ItemID="257013680" PTYPE="2" WIDTH="144" HEIGHT="144" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="0.0476190476190476" LOCALSCY="0.0476190476190476" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="0" RATIO="1" Pagenumber="0" PFILE="Article 3 - 3D Printed Dragons/IMG_9263.jpeg" PRFILE="Embedded Display P3" IRENDER="0" EPROF="Embedded Display P3" path="M0 0 L144 0 L144 144 L0 144 L0 0 Z" copath="M0 0 L144 0 L144 144 L0 144 L0 0 Z" gXpos="703.0008" gYpos="5946.5304" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1"/>
        <PAGEOBJECT XPOS="707.5008" YPOS="6131.0304" OwnPage="18" ItemID="257036336" PTYPE="4" WIDTH="148.5" HEIGHT="216" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L148.5 0 L148.5 216 L0 216 L0 0 Z" copath="M0 0 L148.5 0 L148.5 216 L0 216 L0 0 Z" gXpos="707.5008" gYpos="6131.0304" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle LINESP="12" FONT="Consolas Regular" FONTSIZE="10"/>
                <ITEXT CH="cubic to gyroid for the second attempt. The second attempt produced another inclusion defect that fused several links together. No settings were changed before the third attempt and the print"/>
                <ITEXT FONT="Consolas Regular" FONTSIZE="10" CH=" suffered the same defect as the second attempt."/>
                <ITEXT CH=" The build plate was removed, handwashed over a sink with water and handsoap, "/>
                <ITEXT FONT="Consolas Regular" FONTSIZE="10" CH="dried with a flour sack towel, and placed back in the X1C. The two proceeding prints had no defects."/>
                <trail LINESP="12"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="703.0008" YPOS="6374.0304" OwnPage="18" ItemID="257030672" PTYPE="4" WIDTH="153" HEIGHT="90" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L153 0 L153 90 L0 90 L0 0 Z" copath="M0 0 L153 0 L153 90 L0 90 L0 0 Z" gXpos="703.0008" gYpos="6374.0304" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle LINESP="13" FONT="Consolas Regular" FONTSIZE="10"/>
                <ITEXT CH="The articulation of each final dragons is fully functional and behaves as predicted, having the most freedom about the pitch axis, followed by yaw and then roll. No tools were "/>
                <trail/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="7066.5336" OwnPage="19" ItemID="257033504" PTYPE="4" WIDTH="153" HEIGHT="49.5" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L153 0 L153 49.5 L0 49.5 L0 0 Z" copath="M0 0 L153 0 L153 49.5 L0 49.5 L0 0 Z" gXpos="136.0008" gYpos="7066.5336" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle LINESP="13" FONT="Consolas Regular" FONTSIZE="10"/>
                <ITEXT CH="Because the model was sourced from MakerWorld rather than designed from scratch, this project "/>
                <trail LINESP="13"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="311.5008" YPOS="6126.5304" OwnPage="17" ItemID="257039168" PTYPE="2" WIDTH="144" HEIGHT="144" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="0.0336134453781513" LOCALSCY="0.0336134453781513" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="0" RATIO="1" Pagenumber="0" PFILE="Article 3 - 3D Printed Dragons/IMG_9003.jpeg" PRFILE="Embedded Display P3" IRENDER="0" EPROF="Embedded Display P3" path="M0 0 L144 0 L144 144 L0 144 L0 0 Z" copath="M0 0 L144 0 L144 144 L0 144 L0 0 Z" gXpos="311.5008" gYpos="6126.5304" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1"/>
        <PAGEOBJECT XPOS="136.0008" YPOS="6792.0336" OwnPage="19" ItemID="257027840" PTYPE="4" WIDTH="153" HEIGHT="247.5" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L153 0 L153 247.5 L0 247.5 L0 0 Z" copath="M0 0 L153 0 L153 247.5 L0 247.5 L0 0 Z" gXpos="532.0008" gYpos="6140.0304" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle LINESP="13" FONT="Consolas Regular" FONTSIZE="10"/>
                <ITEXT CH="used to measure the physical properties, but the dual-colored PLA has physical properties roughly equivalent to that of single-colored PLA. The Pink-Blue PLA filament produces in the most visually interesting surface finish, followed by a tie between the Blue-Green PLA filament and the Gold-Magenta PLA filament. The dragons printed at 75% scale provide a more enjoyable fidgeting experience compared to the dragon printed at 125% scale."/>
                <trail/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="6778.5336" OwnPage="19" ItemID="257042000" PTYPE="4" WIDTH="153" HEIGHT="13.5" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L153 0 L153 13.5 L0 13.5 L0 0 Z" copath="M0 0 L153 0 L153 13.5 L0 13.5 L0 0 Z" gXpos="532.0008" gYpos="3518.5176" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle FONT="Consolas Bold Italic" FONTSIZE="10"/>
                <ITEXT FONT="Consolas Bold Italic" FONTSIZE="10" CH="Results Continued"/>
                <trail/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="307.0008" YPOS="6603.0336" OwnPage="19" ItemID="257056160" PTYPE="4" WIDTH="153" HEIGHT="270" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L153 0 L153 270 L0 270 L0 0 Z" copath="M0 0 L153 0 L153 270 L0 270 L0 0 Z" gXpos="307.0008" gYpos="6603.0336" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FONT="Consolas Regular" FONTSIZE="10" CH="demonstrates only that small"/>
                <nbhyphen FONT="Consolas Regular" FONTSIZE="10"/>
                <ITEXT FONT="Consolas Regular" FONTSIZE="10" CH="scale, chain"/>
                <nbhyphen FONT="Consolas Regular" FONTSIZE="10"/>
                <ITEXT FONT="Consolas Regular" FONTSIZE="10" CH="like articulations are feasible; meaningful modifications beyond simple scaling are not possible without developing a fully parametric model. The mechanical differences between single- and dual-colored filament would require a load frame and standard testing methods for 3D prints which would likely be similar to existing tensile strength tests (ASTM D638/ISO 527) [5] but would have to account for the anisotropy of the 3D printed test coupons. "/>
                <trail LINESP="13"/>
            </StoryText>
        </PAGEOBJECT>
