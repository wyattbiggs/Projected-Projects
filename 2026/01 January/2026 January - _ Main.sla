        <PAGEOBJECT XPOS="140.5008" YPOS="4759.524" OwnPage="13" ItemID="255346272" PTYPE="4" WIDTH="148.5" HEIGHT="207" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L148.5 0 L148.5 207 L0 207 L0 0 Z" copath="M0 0 L148.5 0 L148.5 207 L0 207 L0 0 Z" gXpos="140.5008" gYpos="4759.524" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle LINESP="13" FONT="Consolas Regular" FONTSIZE="10"/>
                <ITEXT FONT="Consolas Regular" FONTSIZE="10" CH="To get a feel for the surface finish and appropriate slicing settings, I printed a test Benchy [3 and Fig. 3.1] with BambuLab's default PLA settings.  I then began printing the dragon at 75% scale with the Gold-Magenta PLA filament but it halted about half-way through due to a fan speed issue. This was resolved by replacing the  complete hotend assembly"/>
                <ITEXT CH=" [4]."/>
                <para LINESP="13"/>
            </StoryText>
        </PAGEOBJECT>
