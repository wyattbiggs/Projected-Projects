        <PAGEOBJECT XPOS="311.5008" YPOS="5061.024" OwnPage="13" ItemID="255340608" PTYPE="4" WIDTH="148.5" HEIGHT="99" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L148.5 0 L148.5 99 L0 99 L0 0 Z" copath="M0 0 L148.5 0 L148.5 99 L0 99 L0 0 Z" gXpos="311.5008" gYpos="5061.024" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle LINESP="13" FONT="Consolas Regular" FONTSIZE="10"/>
                <ITEXT CH="The second dragon was printed at 125% scale with the Blue-Green PLA filament. The first attempt had an inclusion defect. The second attempt was successfully printed"/>
                <trail/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="536.5008" YPOS="4921.524" OwnPage="14" ItemID="255354768" PTYPE="4" WIDTH="148.5" HEIGHT="238.5" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L148.5 0 L148.5 238.5 L0 238.5 L0 0 Z" copath="M0 0 L148.5 0 L148.5 238.5 L0 238.5 L0 0 Z" gXpos="536.5008" gYpos="4921.524" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle LINESP="12" FONT="Consolas Regular" FONTSIZE="10"/>
                <ITEXT FONT="Consolas Regular" FONTSIZE="10" CH="Preserving the print settings from the second dragon, the third dragon was printed at 75% scale with the Pink-Blue"/>
                <ITEXT CH=" PLA filament. The first attempt suffered from an inclusion defect which in resulted the dragon's head falling off as well as fused links. The infill was changed from adaptive cubic to gyroid for the second attempt. The second attempt produced another inclusion defect that fused several links together. No settings were changed before the third attempt and the print"/>
                <trail/>
            </StoryText>
        </PAGEOBJECT>
