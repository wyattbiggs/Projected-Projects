        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="1576.008" OwnPage="3" ItemID="389767632" PTYPE="4" WIDTH="153" HEIGHT="247.5" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L153 0 L153 247.5 L0 247.5 L0 0 Z" copath="M0 0 L153 0 L153 247.5 L0 247.5 L0 0 Z" gXpos="532.0008" gYpos="4836.024" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle LINESP="13" FONT="Consolas Regular" FONTSIZE="10"/>
                <ITEXT CH="used to measure the physical properties, but the dual-colored PLA has physical properties roughly equivalent to that of single-colored PLA. The Pink-Blue PLA filament produces in the most visually interesting surface finish, followed by a tie between the Blue-Green PLA filament and the Gold-Magenta PLA filament. The dragons printed at 75% scale provide a more enjoyable fidgeting experience compared to the dragon printed at 125% scale."/>
                <trail/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="136.0008" YPOS="1562.508" OwnPage="3" ItemID="389770464" PTYPE="4" WIDTH="153" HEIGHT="13.5" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L153 0 L153 13.5 L0 13.5 L0 0 Z" copath="M0 0 L153 0 L153 13.5 L0 13.5 L0 0 Z" gXpos="532.0008" gYpos="2214.5112" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
