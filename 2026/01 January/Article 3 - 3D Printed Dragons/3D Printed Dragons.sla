        <PAGEOBJECT XPOS="703.0008" YPOS="730.5048" OwnPage="2" ItemID="389736480" PTYPE="2" WIDTH="144" HEIGHT="144" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="0.0476190476190476" LOCALSCY="0.0476190476190476" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="0" RATIO="1" Pagenumber="0" PFILE="Article 3 - 3D Printed Dragons/IMG_9263.jpeg" PRFILE="Embedded Display P3" IRENDER="0" EPROF="Embedded Display P3" path="M0 0 L144 0 L144 144 L0 144 L0 0 Z" copath="M0 0 L144 0 L144 144 L0 144 L0 0 Z" gXpos="703.0008" gYpos="4642.524" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1"/>
        <PAGEOBJECT XPOS="707.5008" YPOS="915.0048" OwnPage="2" ItemID="389727984" PTYPE="4" WIDTH="148.5" HEIGHT="216" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L148.5 0 L148.5 216 L0 216 L0 0 Z" copath="M0 0 L148.5 0 L148.5 216 L0 216 L0 0 Z" gXpos="707.5008" gYpos="4827.024" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle LINESP="12" FONT="Consolas Regular" FONTSIZE="10"/>
                <ITEXT CH="cubic to gyroid for the second attempt. The second attempt produced another inclusion defect that fused several links together. No settings were changed before the third attempt and the print"/>
                <ITEXT FONT="Consolas Regular" FONTSIZE="10" CH=" suffered the same defect as the second attempt."/>
                <ITEXT CH=" The build plate was removed, handwashed over a sink with water and handsoap, "/>
                <ITEXT FONT="Consolas Regular" FONTSIZE="10" CH="dried with a flour sack towel, and placed back in the X1C. The two proceeding prints had no defects."/>
                <trail LINESP="12"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="703.0008" YPOS="1158.0048" OwnPage="2" ItemID="389739312" PTYPE="4" WIDTH="153" HEIGHT="90" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L153 0 L153 90 L0 90 L0 0 Z" copath="M0 0 L153 0 L153 90 L0 90 L0 0 Z" gXpos="703.0008" gYpos="5070.024" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle LINESP="13" FONT="Consolas Regular" FONTSIZE="10"/>
                <ITEXT CH="The articulation of each final dragons is fully functional and behaves as predicted, having the most freedom about the pitch axis, followed by yaw and then roll. No tools were "/>
