            <StoryText>
                <DefaultStyle LINESP="13" FONT="Consolas Regular" FONTSIZE="10"/>
                <ITEXT CH="The second dragon was printed at 125% scale with the Blue-Green PLA filament. The first attempt had an inclusion defect. The second attempt was printed "/>
                <ITEXT FONT="Consolas Regular" FONTSIZE="10" CH="without defects using an initial layer height of 0.3mm and adaptive cubic infill."/>
                <trail LINESP="13"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="536.5008" YPOS="1103.508" OwnPage="2" ItemID="389725152" PTYPE="4" WIDTH="148.5" HEIGHT="144.4968" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L148.5 0 L148.5 144.497 L0 144.497 L0 0 Z" copath="M0 0 L148.5 0 L148.5 144.497 L0 144.497 L0 0 Z" gXpos="536.5008" gYpos="5015.5272" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle LINESP="12" FONT="Consolas Regular" FONTSIZE="10"/>
                <ITEXT FONT="Consolas Regular" FONTSIZE="10" CH="Preserving the print settings from the second dragon, the third dragon was printed at 75% scale with the Pink-Blue"/>
                <ITEXT CH=" PLA filament. The first attempt suffered from an inclusion defect which in resulted the dragon's head falling off as well as fused links. The infill was changed from adaptive "/>
                <trail/>
            </StoryText>
        </PAGEOBJECT>
