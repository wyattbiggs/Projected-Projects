        <PAGEOBJECT XPOS="707.5008" YPOS="496.5048" OwnPage="0" ItemID="389674176" PTYPE="4" WIDTH="148.5" HEIGHT="94.9967999999999" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L148.5 0 L148.5 94.9968 L0 94.9968 L0 0 Z" copath="M0 0 L148.5 0 L148.5 94.9968 L0 94.9968 L0 0 Z" gXpos="707.5008" gYpos="4408.524" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle LINESP="12" FONT="Consolas Regular" FONTSIZE="10"/>
                <ITEXT FONT="Consolas Regular" FONTSIZE="10" CH="Instead of designing an articulated dragon myself, Taylor Bennett picked out the model [1]. I chose to use exotic filaments since these prints were ornamental rather than functional. I limited the"/>
                <trail LINESP="12"/>
            </StoryText>
        </PAGEOBJECT>
