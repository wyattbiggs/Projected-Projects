        <PAGEOBJECT XPOS="140.5008" YPOS="802.5048" OwnPage="1" ItemID="389688336" PTYPE="4" WIDTH="148.5" HEIGHT="445.5" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L148.5 0 L148.5 445.5 L0 445.5 L0 0 Z" copath="M0 0 L148.5 0 L148.5 445.5 L0 445.5 L0 0 Z" gXpos="140.5008" gYpos="4714.524" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle LINESP="12" FONT="Consolas Regular" FONTSIZE="10"/>
                <ITEXT FONT="Consolas Regular" FONTSIZE="10" CH="To get a feel for the surface finish and appropriate slicing settings, I printed a test Benchy [3 and Fig. 3.1] with BambuLab's default PLA settings. To help communicate the scale of the dragon to Bennett, I  designed and printed a ruler plate [Fig 3.2]. After I got confirmation that 75%  scale of the original model was appropriate, I began printing the dragon with the Gold-Magenta PLA filament but it halted about half-way through due to a fan speed issue. This was resolved by replacing the  complete hotend assembly"/>
                <ITEXT CH=" [4]. "/>
                <ITEXT FONT="Consolas Regular" FONTSIZE="10" CH="The first fully printed dragon had a defect: while printing the first few layers, one of the dragon's links detached from the build plate and imbedded itself into another portion of the dragon, fusing several links together (hereafter  referred to as an inclusion defect). Printing a second time with the same settings produced the first dragon"/>
                <trail LINESPMode="0" LINESP="12"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="311.5008" YPOS="766.5048" OwnPage="1" ItemID="389685504" PTYPE="2" WIDTH="144" HEIGHT="144" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="0.090282131661442" LOCALSCY="0.090282131661442" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="0" RATIO="1" Pagenumber="0" PFILE="Article 3 - 3D Printed Dragons/IMG_8958.jpg" PRFILE="Embedded Display P3" IRENDER="0" EPROF="Embedded Display P3" path="M0 0 L144 0 L144 144 L0 144 L0 0 Z" copath="M0 0 L144 0 L144 144 L0 144 L0 0 Z" gXpos="311.5008" gYpos="4678.524" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1"/>
        <PAGEOBJECT XPOS="307.0008" YPOS="1203.0048" OwnPage="1" ItemID="389691168" PTYPE="4" WIDTH="153" HEIGHT="45" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L153 0 L153 45 L0 45 L0 0 Z" copath="M0 0 L153 0 L153 45 L0 45 L0 0 Z" gXpos="307.0008" gYpos="5115.024" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FONT="Consolas Bold Italic" FONTSIZE="8" CH="Figure 3.1 (Top)"/>
                <ITEXT FONT="Consolas Italic" FONTSIZE="8" CH=": Gold-Magenta Benchy"/>
