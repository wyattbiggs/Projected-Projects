        <PAGEOBJECT XPOS="640.0008" YPOS="1522.008" OwnPage="4" ItemID="206651872" PTYPE="4" WIDTH="216" HEIGHT="378" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L216 0 L216 378 L0 378 L0 0 Z" copath="M0 0 L216 0 L216 378 L0 378 L0 0 Z" gXpos="640.0008" gYpos="1522.008" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FONTSIZE="10" CH="The structure of an article according to IMRAD should look as follows."/>
                <para/>
                <ITEXT FONTSIZE="10" CH="– "/>
                <ITEXT FONT="Arial Italic" FONTSIZE="10" CH="Introduction"/>
                <ITEXT FONTSIZE="10" CH="."/>
                <para ALIGN="0" DIRECTION="0"/>
                <ITEXT FONTSIZE="10" CH="        – Why the study was done."/>
                <para ALIGN="0" DIRECTION="0"/>
                <ITEXT FONTSIZE="10" CH="        – What was researched."/>
                <para ALIGN="0" DIRECTION="0"/>
                <ITEXT FONTSIZE="10" CH="        – Purpose of the study."/>
                <para/>
                <ITEXT FONTSIZE="10" CH="        – What hypotheses were tested."/>
                <para/>
                <ITEXT FONTSIZE="10" CH="– "/>
                <ITEXT FONT="Arial Italic" FONTSIZE="10" CH="Methods"/>
                <ITEXT FONTSIZE="10" CH=" (aka "/>
                <ITEXT FONT="Arial Italic" FONTSIZE="10" CH="Materials and Methods"/>
                <ITEXT FONTSIZE="10" CH=","/>
                <para/>
                <ITEXT FONTSIZE="10" CH="   "/>
                <ITEXT FONT="Arial Italic" FONTSIZE="10" CH="Theoretical Framework"/>
                <ITEXT FONTSIZE="10" CH=")."/>
                <para/>
                <ITEXT FONTSIZE="10" CH="        – When, where, and how the "/>
                <para/>
                <ITEXT FONTSIZE="10" CH="           research was conducted."/>
                <para/>
                <ITEXT FONTSIZE="10" CH="        – What materials were used."/>
                <para/>
                <ITEXT FONTSIZE="10" CH="– "/>
                <ITEXT FONT="Arial Italic" FONTSIZE="10" CH="Results"/>
                <ITEXT FONTSIZE="10" CH="."/>
                <para/>
                <ITEXT FONTSIZE="10" CH="        – What answer was found."/>
                <para/>
                <ITEXT FONTSIZE="10" CH="        – Whether the hypothesis was"/>
                <para/>
                <ITEXT FONTSIZE="10" CH="           tested correctly."/>
                <para/>
                <ITEXT FONTSIZE="10" CH="– "/>
                <ITEXT FONT="Arial Italic" FONTSIZE="10" CH="Discussion"/>
                <ITEXT FONTSIZE="10" CH="."/>
                <para/>
                <ITEXT FONTSIZE="10" CH="        – What the answer implies and"/>
                <para/>
                <ITEXT FONTSIZE="10" CH="           why it matters."/>
                <para/>
                <ITEXT FONTSIZE="10" CH="        – How it fits in with what other"/>
                <para/>
                <ITEXT FONTSIZE="10" CH="           researchers have found."/>
                <para/>
                <ITEXT FONTSIZE="10" CH="        – What are the prospects for"/>
                <para/>
                <ITEXT FONTSIZE="10" CH="           research."/>
                <para/>
                <ITEXT FONTSIZE="10" CH="– Also included in the article structure are "/>
                <ITEXT FONT="Arial Italic" FONTSIZE="10" CH="Title"/>
                <ITEXT FONTSIZE="10" CH=", "/>
                <ITEXT FONT="Arial Italic" FONTSIZE="10" CH=" "/>
                <para/>
                <ITEXT FONT="Arial Italic" FONTSIZE="10" CH="   Annotation"/>
                <ITEXT FONTSIZE="10" CH=", "/>
                <ITEXT FONT="Arial Italic" FONTSIZE="10" CH="Keywords"/>
                <trail/>
            </StoryText>
        </PAGEOBJECT>
